{
  "expo": {
    "name": "Appmake Mobile",
    "slug": "apt-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "scheme": "apt",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.apt.mobile"
    },
    "android": {
      "package": "com.apt.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#2563eb"
      },
      "versionCode": 4
    }
  }
}
