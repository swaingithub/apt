{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "nixpacks",
    "nixpacksPlanPath": "nixpacks.toml"
  },
  "deploy": {
    "startCommand": "./target/release/apt-server",
    "restartPolicyType": "onFailure",
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 10
  }
}
